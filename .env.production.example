API_DOMAIN=api.cloudm.fun
ACME_EMAIL=admin@cloudm.fun

POSTGRES_DB=cloudm
POSTGRES_USER=cloudm
POSTGRES_PASSWORD=change_me
REDIS_MAXMEMORY=256mb

Jwt__Key=change_me_to_a_long_random_secret

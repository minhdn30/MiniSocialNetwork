Email__ResendApiKey=replace_with_resend_api_key

Cloudinary__CloudName=replace_with_cloudinary_cloud_name
Cloudinary__ApiKey=replace_with_cloudinary_api_key
Cloudinary__ApiSecret=replace_with_cloudinary_api_secret

ExternalAuth__Google__AllowedClientIds__0=replace_with_google_client_id

Cors__AllowedOrigins__0=https://cloudm.fun
